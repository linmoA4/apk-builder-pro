<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/editorPane"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/editorToolbarCard"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:tag="panelRaised">

        <Button
            android:id="@+id/btnToggleFiles"
            android:layout_width="64dp"
            android:layout_height="36dp"
            android:text="文件"
            android:textStyle="bold"
            android:tag="ghostButton primary" />

        <TextView
            android:id="@+id/tvEditorProject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="当前项目"
            android:textSize="14sp"
            android:textStyle="bold"
            android:tag="primary" />

        <Button
            android:id="@+id/btnBug"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:text="!"
            android:textStyle="bold"
            android:tag="ghostButton primary" />

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:layout_marginLeft="6dp"
            android:text="↶"
            android:textSize="15sp"
            android:textStyle="bold"
            android:tag="ghostButton primary" />

        <Button
            android:id="@+id/btnRedo"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:layout_marginLeft="6dp"
            android:text="↷"
            android:textSize="15sp"
            android:textStyle="bold"
            android:tag="ghostButton primary" />

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="46dp"
            android:layout_height="36dp"
            android:layout_marginLeft="6dp"
            android:text="查"
            android:textStyle="bold"
            android:tag="ghostButton primary" />

        <Button
            android:id="@+id/btnSaveFile"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnBuild"
            android:layout_width="46dp"
            android:layout_height="36dp"
            android:layout_marginLeft="8dp"
            android:text="▶"
            android:textSize="15sp"
            android:tag="primaryButton primary" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/editorTabsBar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:tag="panel">

        <LinearLayout
            android:id="@+id/editorTabContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingRight="8dp" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvCurrentFilePath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="middle"
        android:maxLines="2"
        android:paddingLeft="12dp"
        android:paddingTop="9dp"
        android:paddingRight="12dp"
        android:paddingBottom="9dp"
        android:text="请选择一个文件"
        android:textSize="12sp"
        android:tag="panel secondary" />

    <LinearLayout
        android:id="@+id/editorInteractionHost"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/fileDrawer"
            android:layout_width="210dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone"
            android:tag="panelRaised">

            <TextView
                android:id="@+id/tvDrawerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="项目文件"
                android:textStyle="bold"
                android:tag="primary" />

            <TextView
                android:id="@+id/tvDrawerHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:text="右滑直接展开完整项目结构。点文件夹进入目录页，点文件直接打开。"
                android:textSize="12sp"
                android:tag="muted" />

            <ListView
                android:id="@+id/lvFiles"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:cacheColorHint="#00000000"
                android:divider="@android:color/transparent"
                android:dividerHeight="4dp"
                android:listSelector="@android:color/transparent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/editorContentColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/suggestionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone"
                android:tag="warningCard">

                <TextView
                    android:id="@+id/tvIssueTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="错误提示"
                    android:textStyle="bold"
                    android:tag="warningText" />

                <TextView
                    android:id="@+id/tvIssueFix"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textIsSelectable="true"
                    android:tag="primary" />

                <Button
                    android:id="@+id/btnCopyFix"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="10dp"
                    android:text="复制修复建议"
                    android:textStyle="bold"
                    android:tag="warnButton primary" />
            </LinearLayout>

            <com.LM.pack.editor.CodeEditorView
                android:id="@+id/etEditor"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:inputType="textMultiLine|textNoSuggestions"
                android:padding="14dp"
                android:textSize="13sp"
                android:tag="editorSurface primary" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
