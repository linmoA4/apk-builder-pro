<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.LM.pack.theme.LiquidGlassBackgroundView
        android:id="@+id/bgSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/topToolbarCard"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:tag="panelRaised">

            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textSize="17sp"
                android:visibility="gone"
                android:tag="ghostButton primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                android:text="@string/main_title"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:tag="primary" />

                <TextView
                    android:id="@+id/tvToolbarSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_subtitle"
                    android:textSize="11sp"
                    android:tag="muted" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="72dp"
                android:layout_height="40dp"
                android:text="@string/settings"
                android:textStyle="bold"
                android:tag="ghostButton primary" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLogs"
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:textSize="1sp" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/addActionOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginRight="18dp"
        android:layout_marginBottom="176dp"
        android:orientation="vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/btnCreateAction"
            android:layout_width="96dp"
            android:layout_height="42dp"
            android:text="@string/create"
            android:textStyle="bold"
            android:tag="ghostButton primary" />

        <Space
            android:layout_width="1dp"
            android:layout_height="16dp" />

        <Button
            android:id="@+id/btnImportAction"
            android:layout_width="96dp"
            android:layout_height="42dp"
            android:text="@string/import_text"
            android:textStyle="bold"
            android:tag="ghostButton primary" />
    </LinearLayout>

    <Button
        android:id="@+id/btnFabAdd"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginRight="18dp"
        android:layout_marginBottom="108dp"
        android:text="+"
        android:textSize="26sp"
        android:tag="primaryButton primary" />

    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#8A091019"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/progressCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:tag="panelRaised">

            <TextView
                android:id="@+id/tvProgressTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/processing"
                android:textSize="18sp"
                android:textStyle="bold"
                android:tag="primary" />

            <TextView
                android:id="@+id/tvProgressMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/please_wait"
                android:textSize="13sp"
                android:tag="secondary" />

            <com.LM.pack.theme.GlassProgressBarView
                android:id="@+id/progressBarFancy"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="0%"
                android:textSize="14sp"
                android:textStyle="bold"
                android:tag="primary" />

            <Button
                android:id="@+id/btnProgressCancel"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="14dp"
                android:text="@string/cancel_build"
                android:textStyle="bold"
                android:visibility="gone"
                android:tag="warnButton primary" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
