<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.LM.pack.theme.LiquidGlassBackgroundView
        android:id="@+id/bgSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/topToolbarCard"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:tag="panelRaised">

            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textSize="17sp"
                android:visibility="gone"
                android:tag="ghostButton primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APK Builder Pro"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:tag="primary" />

                <TextView
                    android:id="@+id/tvToolbarSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="更顺手的手机 APK 工作台"
                    android:textSize="11sp"
                    android:tag="muted" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="72dp"
                android:layout_height="40dp"
                android:text="设置"
                android:textStyle="bold"
                android:tag="ghostButton primary" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:id="@+id/homePane"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/homeProjectsCard"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:tag="panelRaised">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvProjectsTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="项目"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:tag="primary" />

                            <TextView
                                android:id="@+id/tvProjectsSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="最近导入和创建的工程"
                                android:textSize="12sp"
                                android:tag="secondary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvHomeChip"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp"
                            android:text="多主题"
                            android:textSize="11sp"
                            android:tag="chip chipText" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="12dp">

                        <ListView
                            android:id="@+id/lvProjects"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:cacheColorHint="#00000000"
                            android:divider="@android:color/transparent"
                            android:dividerHeight="10dp"
                            android:listSelector="@android:color/transparent"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/emptyState"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="18dp"
                            android:tag="panel">

                            <TextView
                                android:id="@+id/tvEmptyTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="还没有项目"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:tag="primary" />

                            <TextView
                                android:id="@+id/tvEmptySubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="右下角展开后可以创建项目，或者用一个导入入口导入文件夹 / 压缩包。"
                                android:textSize="13sp"
                                android:tag="secondary" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/editorPane"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/editorToolbarCard"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:tag="panelRaised">

                    <Button
                        android:id="@+id/btnToggleFiles"
                        android:layout_width="64dp"
                        android:layout_height="36dp"
                        android:text="文件"
                        android:textStyle="bold"
                        android:tag="ghostButton primary" />

                    <TextView
                        android:id="@+id/tvEditorProject"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="当前项目"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:tag="primary" />

                    <Button
                        android:id="@+id/btnBug"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:text="!"
                        android:textStyle="bold"
                        android:tag="ghostButton primary" />

                    <Button
                        android:id="@+id/btnSaveFile"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnBuild"
                        android:layout_width="46dp"
                        android:layout_height="36dp"
                        android:layout_marginLeft="8dp"
                        android:text="▶"
                        android:textSize="15sp"
                        android:tag="primaryButton primary" />
                </LinearLayout>

                <HorizontalScrollView
                    android:id="@+id/editorTabsBar"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="8dp"
                    android:fillViewport="true"
                    android:scrollbars="none"
                    android:tag="panel">

                    <LinearLayout
                        android:id="@+id/editorTabContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp" />
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvCurrentFilePath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="middle"
                    android:maxLines="2"
                    android:paddingLeft="12dp"
                    android:paddingTop="9dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="9dp"
                    android:text="请选择一个文件"
                    android:textSize="12sp"
                    android:tag="panel secondary" />

                <LinearLayout
                    android:id="@+id/editorInteractionHost"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/fileDrawer"
                        android:layout_width="210dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:visibility="gone"
                        android:tag="panelRaised">

                        <TextView
                            android:id="@+id/tvDrawerTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="项目文件"
                            android:textStyle="bold"
                            android:tag="primary" />

                        <TextView
                            android:id="@+id/tvDrawerHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"
                            android:text="右滑直接展开完整项目结构。点文件夹进入目录页，点文件直接打开。"
                            android:textSize="12sp"
                            android:tag="muted" />

                        <ListView
                            android:id="@+id/lvFiles"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:cacheColorHint="#00000000"
                            android:divider="@android:color/transparent"
                            android:dividerHeight="4dp"
                            android:listSelector="@android:color/transparent" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/editorContentColumn"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/suggestionCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:visibility="gone"
                            android:tag="warningCard">

                            <TextView
                                android:id="@+id/tvIssueTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="错误提示"
                                android:textStyle="bold"
                                android:tag="warningText" />

                            <TextView
                                android:id="@+id/tvIssueFix"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textIsSelectable="true"
                                android:tag="primary" />

                            <Button
                                android:id="@+id/btnCopyFix"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginTop="10dp"
                                android:text="复制修复建议"
                                android:textStyle="bold"
                                android:tag="warnButton primary" />
                        </LinearLayout>

                        <com.LM.pack.editor.CodeEditorView
                            android:id="@+id/etEditor"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fontFamily="monospace"
                            android:gravity="top|start"
                            android:inputType="textMultiLine|textNoSuggestions"
                            android:padding="14dp"
                            android:textSize="13sp"
                            android:tag="editorSurface primary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLogs"
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:textSize="1sp" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/addActionOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginRight="18dp"
        android:layout_marginBottom="176dp"
        android:orientation="vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/btnCreateAction"
            android:layout_width="96dp"
            android:layout_height="42dp"
            android:text="创建"
            android:textStyle="bold"
            android:tag="ghostButton primary" />

        <Space
            android:layout_width="1dp"
            android:layout_height="16dp" />

        <Button
            android:id="@+id/btnImportAction"
            android:layout_width="96dp"
            android:layout_height="42dp"
            android:text="导入"
            android:textStyle="bold"
            android:tag="ghostButton primary" />
    </LinearLayout>

    <Button
        android:id="@+id/btnFabAdd"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginRight="18dp"
        android:layout_marginBottom="108dp"
        android:text="+"
        android:textSize="26sp"
        android:tag="primaryButton primary" />

    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#8A091019"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/progressCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:tag="panelRaised">

            <TextView
                android:id="@+id/tvProgressTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="处理中"
                android:textSize="18sp"
                android:textStyle="bold"
                android:tag="primary" />

            <TextView
                android:id="@+id/tvProgressMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="请稍候..."
                android:textSize="13sp"
                android:tag="secondary" />

            <com.LM.pack.theme.GlassProgressBarView
                android:id="@+id/progressBarFancy"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="0%"
                android:textSize="14sp"
                android:textStyle="bold"
                android:tag="primary" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
