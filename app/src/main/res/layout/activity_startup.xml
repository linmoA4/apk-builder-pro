<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/startupRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.LM.pack.theme.LiquidGlassBackgroundView
        android:id="@+id/bgSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/loadingContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="26dp"
        android:paddingTop="26dp"
        android:paddingRight="26dp"
        android:paddingBottom="26dp">

        <FrameLayout
            android:layout_width="132dp"
            android:layout_height="132dp"
            android:background="@drawable/bg_startup_avatar"
            android:padding="16dp"
            android:tag="panelRaised">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/app_brand" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="正在进入工作台"
            android:textSize="24sp"
            android:textStyle="bold"
            android:tag="primary" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="正在为你恢复项目空间与常用能力"
            android:textSize="14sp"
            android:tag="secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="18dp"
            android:paddingRight="18dp"
            android:paddingBottom="18dp"
            android:tag="panelRaised">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="正在整理启动所需内容"
                android:textSize="17sp"
                android:textStyle="bold"
                android:tag="primary" />

            <TextView
                android:id="@+id/tvStatusHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="整个过程通常只需片刻，请稍等一下。"
                android:textSize="13sp"
                android:tag="secondary" />

            <com.LM.pack.theme.GlassProgressBarView
                android:id="@+id/progressBoot"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvStageWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="7dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="7dp"
                    android:text="欢迎"
                    android:textSize="12sp"
                    android:tag="chip chipText" />

                <TextView
                    android:id="@+id/tvStagePrepare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="7dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="7dp"
                    android:text="准备中"
                    android:textSize="12sp"
                    android:tag="chip chipText" />

                <TextView
                    android:id="@+id/tvStageReady"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="12dp"
                    android:paddingTop="7dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="7dp"
                    android:text="就绪"
                    android:textSize="12sp"
                    android:tag="chip chipText" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginTop="20dp"
            android:text="重试"
            android:textStyle="bold"
            android:visibility="gone"
            android:tag="primaryButton primary" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="164dp"
            android:layout_height="164dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_startup_avatar"
            android:padding="18dp"
            android:tag="panelRaised">

            <ImageView
                android:id="@+id/ivSplashAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/app_brand" />
        </FrameLayout>
    </FrameLayout>

</FrameLayout>
